# ═══════════════════════════════════════════════════════════════
# Xray — Environment Configuration
# Copy to .env in the project root and fill in your values.
# ═══════════════════════════════════════════════════════════════

# ── LLM Provider ──────────────────────────────────────────────
# openrouter | gemini | openai | anthropic | deepseek | groq | cursor
XRAY_LLM_PROVIDER=openrouter
# Alias: LLM_PROVIDER=openrouter

# ── API Keys (only the active provider is required) ───────────
OPENROUTER_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
CURSOR_API_KEY=

# ── Cursor (when XRAY_LLM_PROVIDER=cursor) ───────────────────
# Requires cursor-sdk + Cursor Pro API key (Dashboard → Integrations).
# XRAY_CURSOR_MODE: plan (default, ask-like — no file edits) | agent
XRAY_CURSOR_MODE=plan
# Optional workspace for local agent; empty = project root
XRAY_CURSOR_CWD=

# ── Models ────────────────────────────────────────────────────
# Leave empty to use the provider default.
# Aliases: LLM_MODEL=<same value>
#
# OpenRouter:  anthropic/claude-sonnet-4.5, openrouter/free
# Gemini:      gemini-3-flash-preview
# OpenAI:      gpt-4o, gpt-4o-mini, gpt-5, gpt-5-mini
# Anthropic:   claude-sonnet-4, claude-opus-4 (aliases → dated slugs)
# DeepSeek:    deepseek-chat, deepseek-reasoner
# Groq:        llama-3.3-70b, qwen-qwq (aliases → full slugs)
# Cursor:      composer-2.5, auto
XRAY_DEFAULT_MODEL=

# Reserved for future fallback routing (OpenRouter)
XRAY_FALLBACK_MODEL=openrouter/free

# ── Server ────────────────────────────────────────────────────
# Comma-separated frontend origins (must match where you serve index.html)
XRAY_CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Rate limit: requests per IP per minute (routes under /api/*)
XRAY_RATE_LIMIT=10

# LLM call timeout in seconds (free models may need 60+)
XRAY_LLM_TIMEOUT=60
