# Provedor LLM: openrouter | gemini
XRAY_LLM_PROVIDER=gemini

# --- OpenRouter (quando XRAY_LLM_PROVIDER=openrouter) ---
OPENROUTER_API_KEY=

# --- Google Gemini (quando XRAY_LLM_PROVIDER=gemini) ---
GEMINI_API_KEY=

# Modelo padrão (opcional — se vazio, usa default do provedor)
# openrouter: anthropic/claude-sonnet-4.5
# gemini: gemini-3-flash
XRAY_DEFAULT_MODEL=gemini-3-flash

# Fallback OpenRouter (reservado para uso futuro)
XRAY_FALLBACK_MODEL=openai/gpt-4o-mini

# Origens permitidas no CORS (separadas por vírgula) — origem do frontend
XRAY_CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Rate limit por IP (requisições por minuto)
XRAY_RATE_LIMIT=10

# Timeout (segundos) da chamada ao LLM
XRAY_LLM_TIMEOUT=25
